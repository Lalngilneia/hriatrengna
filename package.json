{
  "name": "memorialqr",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "start": "concurrently \"npm run start --workspace=backend\" \"npm run start --workspace=frontend\"",
    "build": "npm run build --workspace=frontend",
    "migrate": "npm run migrate --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "@sentry/node": "^10.45.0",
    "bullmq": "^5.71.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  }
}
