# ============================================================
# MemorialQR — Environment Variables v2
# Copy to .env and fill in your real values
# ============================================================

NODE_ENV=production
PORT=4000
APP_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com

# ── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=postgresql://memorialqr_user:YOUR_DB_PASSWORD@localhost:5432/memorialqr

# ── JWT ──────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d

# ── ADMIN JWT (separate secret for admin tokens) ─────────────
ADMIN_JWT_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64_CHAR_STRING
ADMIN_JWT_EXPIRES_IN=8h

# ── AFFILIATE JWT (separate secret for affiliate tokens) ──────
# Generate: openssl rand -base64 64
AFFILIATE_JWT_SECRET=REPLACE_WITH_YET_ANOTHER_RANDOM_64_CHAR_STRING

# ── CLOUDFLARE R2 ────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=memorialqr-media
R2_PUBLIC_URL=https://pub-XXXXX.r2.dev

# ── RAZORPAY ─────────────────────────────────────────────────
# Get from razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
# Plan IDs created in Razorpay Dashboard → Subscriptions → Plans
RAZORPAY_MONTHLY_PLAN_ID=plan_XXXXXXXXXXXX
RAZORPAY_YEARLY_PLAN_ID=plan_XXXXXXXXXXXX

# ── RESEND (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=MemorialQR <hello@yourdomain.com>
EMAIL_FROM_NOREPLY=MemorialQR <noreply@yourdomain.com>
# Your personal email — receives daily digest, affiliate alerts, payout reminders
ADMIN_NOTIFY_EMAIL=you@youremail.com
SUPPORT_EMAIL=support@yourdomain.com

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── GOOGLE OAuth ──────────────────────────────────────────────
# Create at console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client
# Authorised redirect URI must be: https://hriatrengna.in/google-callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_SECRET
GOOGLE_REDIRECT_URI=https://hriatrengna.in/google-callback
# Must match APP_URL so redirect_uri computed at runtime stays consistent:
FRONTEND_URL=https://hriatrengna.in

# Web Push Notifications (VAPID)
# Generate fresh keys with: node -e "const {subtle}=require('crypto').webcrypto;(async()=>{const p=await subtle.generateKey({name:'ECDH',namedCurve:'P-256'},true,['deriveKey']);const pub=await subtle.exportKey('raw',p.publicKey);const priv=await subtle.exportKey('jwk',p.privateKey);console.log('PUBLIC='+Buffer.from(pub).toString('base64url'));console.log('PRIVATE='+priv.d);})()"
VAPID_PUBLIC_KEY=BL0JYda9YtrVeiYPa8oLVtVghgBPNF_FvMz-D8r5Zijg6ksQtpMwpt0bMkrmyOxaSx74trX9uW6DBpnQQEOYK-w
VAPID_PRIVATE_KEY=mcs24BkFQEPdzGcU2AemOBEXaEpLRmpxW8VK7E7jfaE
VAPID_EMAIL=mailto:lalngilneia@live.com

# ── Gemini AI (Chat support bot) ─────────────────────────────
# Get key at: console.cloud.google.com → APIs → Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
